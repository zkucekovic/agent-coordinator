#!/usr/bin/env bash
set -euo pipefail

echo "🧪 Running tests..."
# Skip tests that hang (TTY-dependent) or require pytest
SKIP="test_runners.py|test_startup_cli.py|test_editor.py|test_pty_utils_extended.py"
FILES=$(find tests/ -maxdepth 1 -name 'test_*.py' | grep -Ev "$SKIP" | sort)
python3 -m unittest $FILES -v
echo "✅ Tests passed"

echo ""
echo "📦 Building package..."
uvx --from build pyproject-build --outdir /tmp/agent-coordinator-build
echo "✅ Build succeeded"

echo ""
echo "🚀 Push allowed"
